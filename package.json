{
  "name": "fluxforms",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @fluxforms/api exec prisma generate",
    "db:migrate": "pnpm --filter @fluxforms/api exec prisma migrate dev",
    "db:deploy": "pnpm --filter @fluxforms/api exec prisma migrate deploy",
    "db:studio": "pnpm --filter @fluxforms/api exec prisma studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["msgpackr-extract"]
  },
  "devDependencies": {
    "turbo": "^2.9.12",
    "typescript": "^5.4.5",
    "prettier": "^3.3.2"
  }
}
