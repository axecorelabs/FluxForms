# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase (pgbouncer pooled connection for app, direct for Prisma migrations)
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=          # set if your Redis instance requires a password

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Telegram Bots ────────────────────────────────────────────────────────────
TELEGRAM_CREATOR_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CREATOR_BOT_USERNAME=YourCreatorBot
TELEGRAM_FILLER_BOT_TOKEN=9876543210:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_FILLER_BOT_USERNAME=YourFillerBot
TELEGRAM_WEBHOOK_SECRET=          # Random secret, passed as secretToken in setWebhook

# ─── OpenAI / LLM ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_PLAN_STARTER=PLN_xxxxxxxxxxxx    # Paystack recurring plan code for STARTER
PAYSTACK_PLAN_GROWTH=PLN_yyyyyyyyyyyy     # Paystack recurring plan code for GROWTH

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=                        # Long random string, used as x-admin-key header

# ─── Auth (JWT for creator dashboard) ────────────────────────────────────────
JWT_SECRET=                           # Long random string
JWT_EXPIRY=15m

# ─── URLs ─────────────────────────────────────────────────────────────────────
API_URL=https://api.fluxforms.io
ADMIN_URL=https://admin.fluxforms.io
MINI_APP_URL=https://mini.fluxforms.io

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Next.js apps (.env.local in each app dir) ───────────────────────────────
# apps/creator-dashboard/.env.local
#   NEXT_PUBLIC_API_URL=http://localhost:3000
# apps/admin/.env.local
#   NEXT_PUBLIC_API_URL=http://localhost:3000
