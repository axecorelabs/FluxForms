{
  "name": "@fluxforms/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "prisma generate && cd ../.. && pnpm turbo run build --filter='./packages/*' && cd apps/api",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint src",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@fluxforms/shared-types": "workspace:*",
    "@fluxforms/state-machine": "workspace:*",
    "@fluxforms/utils": "workspace:*",
    "@fluxforms/validators": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.17.0",
    "axios": "^1.7.2",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "grammy": "^1.30.0",
    "ioredis": "^5.11.1",
    "openai": "^6.42.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.3.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "prisma": "^5.17.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.4.5"
  }
}
